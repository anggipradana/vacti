{
  "ignores": [
    "node_modules/**",
    "**/node_modules/**",
    "dist/**",
    ".next/**",
    ".nx/**",
    "coverage/**",
    "**/playwright-report/**",
    "**/test-results/**",
  ],
  "config": {
    "MD013": false,
    "MD024": false,
    "MD033": false,
    "MD041": false,
    "MD040": false,
    "MD004": { "style": "dash" },
    "MD007": { "indent": 2 },
    "MD022": true,
    "MD031": true,
    "MD047": true,
  },
}
