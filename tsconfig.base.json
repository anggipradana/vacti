{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@vacti/core": ["libs/core/src/index.ts"],
      "@vacti/config": ["libs/config/src/index.ts"],
      "@vacti/db": ["libs/db/src/index.ts"],
      "@vacti/auth": ["libs/auth/src/index.ts"],
      "@vacti/queue": ["libs/queue/src/index.ts"],
      "@vacti/ui": ["libs/ui/src/index.ts"],
      "@vacti/recon": ["libs/recon/src/index.ts"],
      "@vacti/threat-intel": ["libs/threat-intel/src/index.ts"],
      "@vacti/reports": ["libs/reports/src/index.ts"],
      "@vacti/api": ["libs/api/src/index.ts"],
      "@vacti/integrations": ["libs/integrations/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
