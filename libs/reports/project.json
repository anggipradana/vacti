{
  "name": "@vacti/reports",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/reports/src",
  "tags": ["lang:ts", "scope:lib"],
  "targets": {
    "typecheck": { "executor": "nx:run-commands", "options": { "command": "tsc -p libs/reports/tsconfig.json" } },
    "lint": { "executor": "nx:run-commands", "options": { "command": "eslint libs/reports/src" } },
    "test:quick": { "executor": "nx:run-commands", "options": { "command": "vitest run --root libs/reports" } },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --config libs/reports/vitest.integration.config.ts" }
    }
  }
}
