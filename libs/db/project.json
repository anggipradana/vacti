{
  "name": "@vacti/db",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/db/src",
  "tags": ["lang:ts", "scope:lib"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/db/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint libs/db/src"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --root libs/db"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config libs/db/vitest.integration.config.ts"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx libs/db/src/seed.ts"
      }
    }
  }
}
