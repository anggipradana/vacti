{
  "name": "@vacti/auth",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/auth/src",
  "tags": ["lang:ts", "scope:lib"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p libs/auth/tsconfig.json" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint libs/auth/src" }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --root libs/auth" }
    }
  }
}
