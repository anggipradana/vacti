{
  "name": "@vacti/api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/api/src",
  "tags": ["lang:ts", "scope:lib"],
  "targets": {
    "typecheck": { "executor": "nx:run-commands", "options": { "command": "tsc -p libs/api/tsconfig.json" } },
    "lint": { "executor": "nx:run-commands", "options": { "command": "eslint libs/api/src" } },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --config libs/api/vitest.integration.config.ts" }
    }
  }
}
