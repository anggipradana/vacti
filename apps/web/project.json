{
  "name": "@vacti/web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "tags": ["lang:ts", "scope:web"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/web/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint apps/web/src"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build apps/web"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev apps/web -p 3000"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start apps/web -p 3000"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test -c apps/web/playwright.config.ts"
      }
    }
  }
}
