{
  "name": "mandraguna-cli",
  "sourceRoot": "apps/mandraguna-cli",
  "projectType": "application",
  "tags": ["type:app", "platform:cli", "lang:rust", "domain:vacti"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release --manifest-path apps/mandraguna-cli/Cargo.toml && mkdir -p apps/mandraguna-cli/dist && cp apps/mandraguna-cli/target/release/mandraguna-cli apps/mandraguna-cli/dist/mandraguna-cli"
      },
      "outputs": ["{projectRoot}/dist", "{projectRoot}/target"]
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fetch --manifest-path apps/mandraguna-cli/Cargo.toml"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt --manifest-path apps/mandraguna-cli/Cargo.toml"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt --manifest-path apps/mandraguna-cli/Cargo.toml -- --check"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cargo fmt --manifest-path apps/mandraguna-cli/Cargo.toml -- --check",
          "cargo clippy --manifest-path apps/mandraguna-cli/Cargo.toml --all-targets -- -D warnings"
        ],
        "parallel": false
      }
    },
    "deny:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo deny --manifest-path apps/mandraguna-cli/Cargo.toml check"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/Cargo.lock", "{projectRoot}/deny.toml"]
    },
    "msrv:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo hack --manifest-path apps/mandraguna-cli/Cargo.toml check --rust-version"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"]
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --manifest-path apps/mandraguna-cli/Cargo.toml --"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo check --manifest-path apps/mandraguna-cli/Cargo.toml --all-targets"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --manifest-path apps/mandraguna-cli/Cargo.toml --lib"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo llvm-cov --manifest-path apps/mandraguna-cli/Cargo.toml --lib --fail-under-lines 90"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --manifest-path apps/mandraguna-cli/Cargo.toml --tests"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs", "{projectRoot}/tests/**/*.rs"]
    },
    "specs:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Phase 0 — specs:coverage stubbed; cucumber harness is future work'"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'no-op: target not applicable for this project'"
      },
      "cache": true
    },
    "test-coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'no-op: target not applicable for this project'"
      },
      "cache": true
    }
  }
}
