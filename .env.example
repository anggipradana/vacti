# vacti environment — copy to `.env` and fill in real values.
# Files matching `.env*` are git-ignored EXCEPT `.env.example`. Never commit secrets.

# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgres://vacti:vacti@localhost:5432/vacti

# --- Security ---
# 32-byte base64 key for AES-256-GCM vault encryption (openssl rand -base64 32)
ENCRYPTION_KEY=
# Session signing secret (openssl rand -base64 32)
SESSION_SECRET=

# --- First-run admin (seed) ---
ADMIN_EMAIL=admin@vacti.local
ADMIN_PASSWORD=

# --- External APIs (optional — features degrade gracefully when absent) ---
OTX_API_KEY=
LEAKCHECK_API_KEY=
# VirusTotal passive DNS for passive recon (Wayback Machine works without any key)
VT_API_KEY=
# URLScan.io (passive recon; works key-less but rate-limited)
URLSCAN_API_KEY=
# Optional outbound proxy for worker OSINT/deep-fetch traffic (http(s):// or socks5://)
PROXY_URL=

# --- AI providers (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
